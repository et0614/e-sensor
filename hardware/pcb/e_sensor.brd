<param name="rvMicroViaInner" value="0"/>
<param name="rlMinPadTop" value="5mil"/>
<param name="rlMaxPadTop" value="80mil"/>
<param name="rlMinPadInner" value="10mil"/>
<param name="rlMaxPadInner" value="20mil"/>
