<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<!--<string>UIInterfaceOrientationLandscapeLeft</string>-->
		<!--<string>UIInterfaceOrientationLandscapeRight</string>-->
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<!--<string>UIInterfaceOrientationLandscapeLeft</string>-->
		<!--<string>UIInterfaceOrientationLandscapeRight</string>-->
	</array>
	<!--
	  iPad の multitasking (Slide Over / Split View / Stage Manager) を無効化する。
	  これを true にしないと UISupportedInterfaceOrientations~ipad に 4 方向すべて
	  含めるよう Apple のバリデーションに要求される。本アプリは縦向きのみで運用する
	  ため multitasking から opt out して縦 2 方向だけの宣言を許容させる。
	-->
	<key>UIRequiresFullScreen</key>
	<true/>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
</dict>
</plist>
